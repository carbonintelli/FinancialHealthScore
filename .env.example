# Carbon Intelligence (ci.sustainow.in)
CARBON_INTELLIGENCE_API_KEY=
CARBON_INTELLIGENCE_BASE_URL=https://ci.sustainow.in/api
USE_MOCK_CARBON_DATA=true

# Credit Bureau (CIBIL/CRISIL) — live pull when key set
CREDIT_BUREAU_API_KEY=
CREDIT_BUREAU_BASE_URL=https://api.cibil.com

# Tax Verification (GSTN/ITR)
TAX_API_KEY=
TAX_API_BASE_URL=https://api.gst.gov.in

# Legal Search (e-Courts/MCA)
LEGAL_API_KEY=
LEGAL_API_BASE_URL=https://api.ecourts.gov.in

# Document Intelligence (OCR)
DOCUMENT_API_KEY=
DOCUMENT_API_BASE_URL=https://api.document-intel.local

# Tally ERP connector (optional — demo import when unset)
TALLY_API_URL=
TALLY_API_KEY=

# Zoho Books connector (optional — demo import when unset)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORGANIZATION_ID=
ZOHO_BOOKS_API_URL=https://books.zoho.in/api/v3

# Account Aggregator (RBI AA Framework)
ACCOUNT_AGGREGATOR_API_KEY=
ACCOUNT_AGGREGATOR_BASE_URL=https://api.accountaggregator.ndml.in
AA_CONSENT_REDIRECT_URL=https://consent.accountaggregator.example/authorize

# UPI Merchant Analytics
UPI_ANALYTICS_API_KEY=
UPI_ANALYTICS_BASE_URL=https://api.upi-analytics.example

# EPFO Establishment Compliance
EPFO_API_KEY=
EPFO_BASE_URL=https://api.epfo.gov.in

# Webhook secret for near-real-time alternate-data reassessment
WEBHOOK_SECRET=

# Use mock data for all integrations when keys not set
USE_MOCK_INTEGRATIONS=true

HOST=0.0.0.0
PORT=8080
DEBUG=false

# Platform auth & database
SECRET_KEY=change-me-in-production-use-long-random-string
JWT_EXPIRE_MINUTES=480
DATABASE_URL=sqlite:///./data/financial_health.db
FRONTEND_URL=http://localhost:8080

# AI Agents (optional — uses rule-based fallback when unset)
OPENAI_API_KEY=

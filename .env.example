# Carbon Intelligence (ci.sustainow.in) Partner API Key
# Obtain from Carbon Intelligence administrators (prefix: ci_live_)
CARBON_INTELLIGENCE_API_KEY=

# Base URL for Carbon Intelligence service
CARBON_INTELLIGENCE_BASE_URL=https://ci.sustainow.in/api

# Server configuration
HOST=0.0.0.0
PORT=8080
DEBUG=false

# Use mock carbon data when API key is not configured (demo mode)
USE_MOCK_CARBON_DATA=true
